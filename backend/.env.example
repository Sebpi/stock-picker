# Core app settings
# Generate a long random value for SECRET_KEY before running in a stable environment.
SECRET_KEY=replace_with_a_long_random_secret
ALLOWED_ORIGINS=http://localhost:8000,https://your-subdomain.ngrok-free.app
ALLOWED_HOSTS=localhost,127.0.0.1,*.ngrok-free.app,*.ngrok-free.dev,*.ngrok.io
ALLOW_NGROK_ORIGINS=true
REQUIRE_HTTPS=true
APP_URL=https://your-subdomain.ngrok-free.app

# Optional path override for the sentiment scanner helper script.
# Defaults to backend/sentiment_scanner.py when unset.
SENTIMENT_SCANNER_PATH=

# Claude AI (required for AI Advisor + Predictions tabs)
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
STOCK_RESEARCH_MAX_TOKENS=1600
RECOMMEND_MAX_TOKENS=800
SEARCH_RESULTS_LIMIT=12
SEARCH_INFO_TIMEOUT_SEC=2.5
PREDICTIONS_INCLUDE_STOCK_RESEARCH=false
PREDICTIONS_UNIVERSE_FILL_LIMIT=6
PREDICTIONS_MAX_TOKENS=2048

# ── Email Alerts (Gmail recommended) ──────────────────────────
# Use a Gmail App Password (not your normal password)
# Enable at: myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password_here
ALERT_EMAIL=email_to_receive_alerts@gmail.com

# ── SMS Alerts via Twilio (optional) ──────────────────────────
# Sign up free at twilio.com — free trial includes SMS credits
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
TWILIO_TO_NUMBER=+1xxxxxxxxxx

# ── Alert Thresholds ──────────────────────────────────────────
SWING_THRESHOLD_PCT=3.0        # Alert if stock moves 3%+ from prev close
MOMENTUM_THRESHOLD_PCT=1.5     # Alert if stock moves 1.5%+ in 5 minutes
VOLUME_SURGE_MULTIPLIER=3.0    # Alert if volume is 3x+ daily average
ALERT_COOLDOWN_MINUTES=30      # Min minutes between alerts for same ticker

# ── Recommendation Alert Tuning ───────────────────────────────
ALERT_RECOMMENDATION_COOLDOWN_MINUTES=720  # Hours between repeat recommendation alerts (default 12h)
ALERT_RECOMMENDATION_SNAPSHOT_MINUTES=30   # How often the recommendation snapshot refreshes
ALERT_TOP_BUYS=3                           # Max BUY recommendations per alert email
ALERT_TOP_SELLS=3                          # Max SELL signals per alert email
ALERT_BUY_MIN_SCORE=72                     # Minimum conviction score to trigger a BUY alert
ALERT_SELL_MAX_SCORE=42                    # Maximum score before triggering a SELL alert
ALERT_PRICE_SWING_PCT=3.0                  # Min % price move since last alert to send a new email
