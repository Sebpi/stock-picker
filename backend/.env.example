# Claude AI (required for AI Advisor + Predictions tabs)
ANTHROPIC_API_KEY=your_api_key_here

# ── Email Alerts (Gmail recommended) ──────────────────────────
# Use a Gmail App Password (not your normal password)
# Enable at: myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password_here
ALERT_EMAIL=email_to_receive_alerts@gmail.com

# ── SMS Alerts via Twilio (optional) ──────────────────────────
# Sign up free at twilio.com — free trial includes SMS credits
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
TWILIO_TO_NUMBER=+1xxxxxxxxxx

# ── Alert Thresholds ──────────────────────────────────────────
SWING_THRESHOLD_PCT=3.0        # Alert if stock moves 3%+ from prev close
MOMENTUM_THRESHOLD_PCT=1.5     # Alert if stock moves 1.5%+ in 5 minutes
VOLUME_SURGE_MULTIPLIER=3.0    # Alert if volume is 3x+ daily average
ALERT_COOLDOWN_MINUTES=30      # Min minutes between alerts for same ticker
